# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# SEC EDGAR User-Agent (required by SEC; use real contact)
# https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT=Windvane Research dan@example.com

# Database & data paths (optional, defaults to ./data/)
WINDVANE_DATA_DIR=./data
WINDVANE_REPORTS_DIR=./reports

# LLM model
WINDVANE_MODEL=claude-sonnet-4-5-20250929

# Scoring window
WINDVANE_ROLLING_WINDOW=200
WINDVANE_COLD_START_MU=0.30
WINDVANE_COLD_START_SIGMA=0.15
WINDVANE_Z_THRESHOLD=2.0
